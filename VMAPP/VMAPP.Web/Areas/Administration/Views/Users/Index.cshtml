@model IEnumerable<UserListViewModel>

@{
    ViewData["Title"] = "Users";
}

<div class="table-wrapper">
    <div class="table-box">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>@ViewData["Title"]</h2>
            <a asp-area="Administration" asp-controller="Users" asp-action="Create" class="btn btn-sm btn-primary">
                <i class="fas fa-plus"></i> Create User
            </a>
        </div>

        <table id="usersTable" class="datatable table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Email</th>
                    <th>City</th>
                    <th>Address</th>
                    <th>User Type</th>
                    <th>Roles</th>
                    <th class="text-center action-col">Details</th>
                    <th class="text-center action-col">Edit</th>
                    <th class="text-center action-col">Delete</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="text-break">@user.Email</td>
                        <td>@user.City</td>
                        <td class="text-break">@user.Address</td>
                        <td>@user.UserType</td>
                        <td>@string.Join(", ", user.Roles)</td>
                        <td class="text-center action-col">
                            <a asp-area="Administration"
                               asp-controller="Users"
                               asp-action="Details"
                               asp-route-id="@user.Id"
                               class="btn btn-info btn-sm">
                                <i class="fas fa-info-circle"></i> Details
                            </a>
                        </td>
                        <td class="text-center action-col">
                            <a asp-area="Administration"
                               asp-controller="Users"
                               asp-action="Edit"
                               asp-route-id="@user.Id"
                               class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                        </td>
                        <td class="text-center action-col">
                            <a asp-area="Administration"
                               asp-controller="Users"
                               asp-action="Delete"
                               asp-route-id="@user.Id"
                               class="btn btn-sm btn-danger">
                                <i class="fas fa-trash"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>
