@model UserDetailsViewModel

@{
    ViewData["Title"] = "Delete User";
}

<div class="form-wrapper">
    <div class="form-box">
        <h2 class="text-center mb-4 text-danger">@ViewData["Title"]</h2>

        <form asp-area="Administration" asp-controller="Users" asp-action="Delete" method="post" asp-antiforgery="true">
            <input name="id" type="hidden" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input class="form-control" value="@Model.Email" disabled />
            </div>

            <div class="mb-3">
                <label class="form-label">City</label>
                <input class="form-control" value="@Model.City" disabled />
            </div>

            <div class="mb-3">
                <label class="form-label">Address</label>
                <input class="form-control" value="@Model.Address" disabled />
            </div>

            <div class="mb-3">
                <label class="form-label">Roles</label>
                <input class="form-control" value="@string.Join(", ", Model.Roles)" disabled />
            </div>

            <div class="d-flex gap-2">
                <button type="submit"
                        class="btn btn-danger btn-sm">
                    <i class="fas fa-trash"></i> Delete
                </button>
                <a asp-area="Administration" asp-controller="Users" asp-action="Index" class="btn btn-secondary btn-sm">Cancel</a>
            </div>
        </form>
    </div>
</div>
