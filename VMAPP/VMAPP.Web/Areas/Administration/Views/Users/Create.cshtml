@model CreateUserViewModel

@{
    ViewData["Title"] = "Create User";
}

<div class="form-wrapper">
    <div class="form-box">
        <h2 class="text-center mb-4">@ViewData["Title"]</h2>

        <form asp-area="Administration" asp-controller="Users" asp-action="Create" method="post" asp-antiforgery="true">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Password"></label>
                    <div class="input-group">
                        <input asp-for="Password" class="form-control" type="password" />
                        <button class="btn btn-outline-secondary" type="button"
                                data-toggle-password="Password" tabindex="-1"
                                title="Show/hide password">
                            <i class="bi bi-eye-slash"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="City"></label>
                    <input asp-for="City" class="form-control" />
                    <span asp-validation-for="City" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Address"></label>
                    <input asp-for="Address" class="form-control" />
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="SelectedRole"></label>
                    <select asp-for="SelectedRole"
                            id="roleSelect"
                            class="form-select"
                            asp-items="@(ViewBag.Roles as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)">
                        <option value="">-- Select Role --</option>
                    </select>
                    <span asp-validation-for="SelectedRole" class="text-danger"></span>
                </div>
            </div>

            <div id="insurance-section" class="row" style="display:none">
                <div class="col-md-6 mb-3">
                    <label asp-for="InsuranceCompanyId">Insurance Company</label>
                    <select asp-for="InsuranceCompanyId"
                            class="form-select"
                            asp-items="@(ViewBag.InsuranceCompanies as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)">
                        <option value="">-- Select Insurance Company --</option>
                    </select>
                    <span asp-validation-for="InsuranceCompanyId" class="text-danger"></span>
                </div>
            </div>

            <div id="vehicleservice-section" class="row" style="display:none">
                <div class="col-md-6 mb-3">
                    <label asp-for="VehicleServiceId">Vehicle Service</label>
                    <select asp-for="VehicleServiceId"
                            class="form-select"
                            asp-items="@(ViewBag.VehicleServices as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)">
                        <option value="">-- Select Vehicle Service --</option>
                    </select>
                    <span asp-validation-for="VehicleServiceId" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-sm">Create</button>
                <a asp-area="Administration" asp-controller="Users" asp-action="Index" class="btn btn-secondary btn-sm">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const roleSelect = document.getElementById('roleSelect');
            const insuranceSection = document.getElementById('insurance-section');
            const vehicleServiceSection = document.getElementById('vehicleservice-section');

            function toggleSections() {
                const role = roleSelect.value;
                insuranceSection.style.display = role === '@VMAPP.Common.GlobalConstant.InsuranceCompanyRoleName' ? '' : 'none';
                vehicleServiceSection.style.display = role === '@VMAPP.Common.GlobalConstant.VehicleServiceRoleName' ? '' : 'none';
            }

            roleSelect.addEventListener('change', toggleSections);
            toggleSections();
        })();
    </script>
}
