@model IEnumerable<VMAPP.Web.Models.AnnualReviewModels.AnnualReviewCompanyViewModel>
@using VMAPP.Common
@{
    this.ViewData["Title"] = "Annual Review Companies";
}

<div class="table-wrapper">
    <div class="table-box">

        <h2 class="text-center mb-4">@this.ViewData["Title"]</h2>
        <div class="d-flex justify-content-start mb-3">
            @if (User.IsInRole(GlobalConstant.AdministratorRoleName))
            {
                <a asp-controller="AnnualReview"
                   asp-action="AddAnnualReviewCompany"
                   class="btn btn-sm btn-primary">
                    Create New Annual Review Company
                </a>
            }
        </div>

        <table id="annualReviewCompaniesTable" class="datatable table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>City</th>
                    <th>Address</th>
                    <th>Created On</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th class="text-center action-col">Details</th>
                    <th class="text-center action-col">Edit</th>
                    <th class="text-center action-col">Delete</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var company in Model)
                {
                    <tr>
                        <td class="fw-semibold text-break">@company.Name</td>
                        <td>@company.City</td>
                        <td class="text-break">@company.Address</td>
                        <td>@company.CreatedOn.ToString("dd.MM.yyyy")</td>

                        <td class="text-break contact-email">
                            <a href="mailto:@company.Email" class="text-decoration-none">@company.Email</a>
                        </td>

                        <td class="contact-phone">
                            <a href="tel:@company.Phone" class="text-decoration-none">@company.Phone</a>
                        </td>

                        <td class="text-center action-col">
                            <a asp-controller="AnnualReview"
                               asp-action="Details"
                               asp-route-id="@company.Id"
                               class="btn btn-info btn-sm">
                                <i class="fas fa-info-circle"></i> Details
                            </a>
                        </td>

                        <td class="text-center action-col">
                            @if (User.IsInRole(GlobalConstant.AdministratorRoleName))
                            {
                                <a asp-controller="AnnualReview"
                                   asp-action="EditAnnualReviewCompany"
                                   asp-route-id="@company.Id"
                                   class="btn btn-sm btn-outline-primary me-1">
                                    Edit
                                </a>
                            }
                        </td>

                        <td class="text-center action-col">
                            @if (User.IsInRole(GlobalConstant.AdministratorRoleName))
                            {
                                <button type="button"
                                        class="btn btn-sm btn-danger btn-delete-company"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteCompanyModal"
                                        data-company-id="@company.Id"
                                        data-company-name="@company.Name">
                                    Delete
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="deleteCompanyModal" tabindex="-1" aria-labelledby="deleteCompanyModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteCompanyModalLabel">Confirm Delete</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete the annual review company "<span id="companyName"></span>"?
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deleteCompanyForm" asp-controller="AnnualReview" asp-action="DeleteAnnualReviewCompany" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="companyId" />
                    <button type="submit" class="btn btn-danger">Delete</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/annualReviewCompanies.js" asp-append-version="true"></script>
}
