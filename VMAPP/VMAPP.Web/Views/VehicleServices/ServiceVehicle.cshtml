@model VMAPP.Web.Models.VehicleServiceCars.ServiceVehicleViewModel

@{
    ViewData["Title"] = $"{Model.CarBrand} {Model.CarModel} — Service Records";
}

<div class="table-wrapper">
    <div class="table-box">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>@ViewData["Title"]</h2>
            <a asp-controller="VehicleServices"
               asp-action="Details"
               asp-route-id="@Model.ServiceId"
               class="btn btn-secondary btn-sm">
                <i class="fas fa-arrow-left"></i> Back to Service
            </a>
        </div>

        <div class="card mb-4">
            <div class="card-header table-dark text-white fw-semibold">
                Vehicle Information
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">VIN</label>
                        <input class="form-control" value="@Model.VIN" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Brand</label>
                        <input class="form-control" value="@Model.CarBrand" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Model</label>
                        <input class="form-control" value="@Model.CarModel" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Year</label>
                        <input class="form-control" value="@Model.CreatedOnYear" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Color</label>
                        <input class="form-control" value="@Model.Color" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Type</label>
                        <input class="form-control" value="@Model.VehicleType" disabled />
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Service Records (@Model.ServiceRecords.Count)</h5>
            <button type="button" class="btn btn-primary btn-sm"
                    data-bs-toggle="modal" data-bs-target="#addRecordModal">
                <i class="fas fa-plus"></i> Add Service Record
            </button>
        </div>

        <table id="serviceRecordsTable"
               class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Description</th>
                    <th>Service Date</th>
                    <th>Cost</th>
                    <th class="text-center action-col">Details</th>
                    <th class="text-center action-col">Edit</th>
                    <th class="text-center action-col">Delete</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var record in Model.ServiceRecords)
                {
                    <tr>
                        <td class="text-truncate" style="max-width: 300px">@record.Description</td>
                        <td>@record.ServiceDate.ToString("dd.MM.yyyy")</td>
                        <td>@record.Cost.ToString("F2")</td>
                        <td class="text-center action-col">
                            <button type="button"
                                    class="btn btn-info btn-sm btn-record-details"
                                    data-id="@record.Id">
                                <i class="fas fa-info-circle"></i> Details
                            </button>
                        </td>
                        <td class="text-center action-col">
                            <button type="button"
                                    class="btn btn-outline-primary btn-sm btn-record-edit"
                                    data-id="@record.Id">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                        </td>
                        <td class="text-center action-col">
                            <button type="button"
                                    class="btn btn-danger btn-sm btn-record-delete"
                                    data-id="@record.Id"
                                    data-description="@record.Description">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>

@Html.AntiForgeryToken()
<input type="hidden" id="hiddenVehicleId" value="@Model.VehicleId" />
<input type="hidden" id="hiddenServiceId" value="@Model.ServiceId" />

<div class="modal fade" id="addRecordModal" tabindex="-1"
     aria-labelledby="addRecordModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addRecordModalLabel">
                    <i class="fas fa-plus"></i> Add Service Record
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Description <span class="text-danger">*</span>
                    </label>
                    <textarea id="addDescription" class="form-control" rows="3"
                              placeholder="Describe the service performed..."
                              maxlength="1500"></textarea>
                    <div id="addDescriptionError" class="text-danger small d-none"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Service Date <span class="text-danger">*</span>
                    </label>
                    <input type="date" id="addServiceDate" class="form-control" />
                    <div id="addServiceDateError" class="text-danger small d-none"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Cost <span class="text-danger">*</span>
                    </label>
                    <input type="number" id="addCost" class="form-control"
                           min="0" step="0.01" placeholder="0.00" />
                    <div id="addCostError" class="text-danger small d-none"></div>
                </div>
                <div id="addRecordError" class="alert alert-danger d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSubmitAdd">
                    <i class="fas fa-save"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="detailsRecordModal" tabindex="-1"
     aria-labelledby="detailsRecordModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailsRecordModalLabel">
                    <i class="fas fa-info-circle"></i> Service Record Details
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea id="detailsDescription" class="form-control" rows="4" disabled></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Service Date</label>
                    <input type="text" id="detailsServiceDate" class="form-control" disabled />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Cost</label>
                    <input type="text" id="detailsCost" class="form-control" disabled />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editRecordModal" tabindex="-1"
     aria-labelledby="editRecordModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editRecordModalLabel">
                    <i class="fas fa-edit"></i> Edit Service Record
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editRecordId" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Description <span class="text-danger">*</span>
                    </label>
                    <textarea id="editDescription" class="form-control" rows="3"
                              maxlength="1500"></textarea>
                    <div id="editDescriptionError" class="text-danger small d-none"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Service Date <span class="text-danger">*</span>
                    </label>
                    <input type="date" id="editServiceDate" class="form-control" />
                    <div id="editServiceDateError" class="text-danger small d-none"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Cost <span class="text-danger">*</span>
                    </label>
                    <input type="number" id="editCost" class="form-control"
                           min="0" step="0.01" />
                    <div id="editCostError" class="text-danger small d-none"></div>
                </div>
                <div id="editRecordError" class="alert alert-danger d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSubmitEdit">
                    <i class="fas fa-save"></i> Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteRecordModal" tabindex="-1"
     aria-labelledby="deleteRecordModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteRecordModalLabel">
                    <i class="fas fa-trash"></i> Confirm Delete
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this service record?
                <strong id="deleteRecordDescription" class="d-block mt-2 text-break"></strong>
                <div id="deleteRecordError" class="alert alert-danger mt-3 d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="btnConfirmDelete">
                    <i class="fas fa-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/serviceVehicle.js" asp-append-version="true"></script>
}