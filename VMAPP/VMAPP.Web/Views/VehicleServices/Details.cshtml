@model VMAPP.Web.Models.VehicleServiceModels.VehicleServiceDetailsViewModel

@{
    ViewData["Title"] = "Service Details — " + Model.Name;
}

<div class="table-wrapper">
    <div class="table-box">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>@ViewData["Title"]</h2>
            @if (User.IsInRole(VMAPP.Common.GlobalConstant.AdministratorRoleName))
            {
                <a asp-controller="VehicleServices" asp-action="Index" class="btn btn-secondary btn-sm">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            }
        </div>

        <div class="card mb-4">
            <div class="card-header table-dark text-dark fw-semibold">
                Service Information
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Name</label>
                        <input class="form-control" value="@Model.Name" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">City</label>
                        <input class="form-control" value="@Model.City" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Address</label>
                        <input class="form-control" value="@Model.Address" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Created On</label>
                        <input class="form-control" value="@Model.CreatedOn.ToString("dd.MM.yyyy")" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Email</label>
                        <input class="form-control" value="@Model.Email" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Phone</label>
                        <input class="form-control" value="@Model.Phone" disabled />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea class="form-control" rows="3" disabled>@Model.Description</textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Assigned Vehicles (@Model.Vehicles.Count)</h5>
            <button type="button"
                    class="btn btn-primary btn-sm"
                    data-bs-toggle="modal"
                    data-bs-target="#addVehicleModal">
                <i class="fas fa-plus"></i> Add Vehicle
            </button>
        </div>

        <table id="vehiclesTable"
               class="datatable table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>VIN</th>
                    <th>Brand</th>
                    <th>Model</th>
                    <th>Year</th>
                    <th>Color</th>
                    <th>Type</th>
                    <th class="text-center action-col">Service</th>
                    <th class="text-center action-col">Remove</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var vehicle in Model.Vehicles)
                {
                    <tr>
                        <td class="fw-semibold">@vehicle.VIN</td>
                        <td>@vehicle.CarBrand</td>
                        <td>@vehicle.CarModel</td>
                        <td>@vehicle.CreatedOnYear</td>
                        <td>@vehicle.Color</td>
                        <td>@vehicle.VehicleType</td>
                        <td class="text-center action-col">
                            <a asp-controller="VehicleServices"
                               asp-action="ServiceVehicle"
                               asp-route-vehicleId="@vehicle.Id"
                               asp-route-serviceId="@Model.Id"
                               class="btn btn-success btn-sm">
                                <i class="fas fa-wrench"></i> Service
                            </a>
                        </td>
                        <td class="text-center action-col">
                            <button type="button"
                                    class="btn btn-danger btn-sm btn-remove-vehicle"
                                    data-vehicle-id="@vehicle.Id"
                                    data-vehicle-vin="@vehicle.VIN">
                                <i class="fas fa-times"></i> Remove
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>

<div class="modal fade" id="addVehicleModal" tabindex="-1"
     aria-labelledby="addVehicleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="addVehicleModalLabel">
                    <i class="fas fa-car"></i> Add Vehicle to Service
                </h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                @Html.AntiForgeryToken()

                <input type="hidden" id="currentServiceId" value="@Model.Id" />

                <div class="mb-3">
                    <label for="vinSearchInput" class="form-label fw-semibold">Search by VIN</label>
                    <div class="input-group">
                        <input type="text" id="vinSearchInput"
                               class="form-control text-uppercase"
                               placeholder="Enter 17-character VIN..."
                               maxlength="17" />
                        <button class="btn btn-outline-primary" type="button" id="btnSearchVin">
                            <i class="fas fa-search"></i> Search
                        </button>
                    </div>
                    <div id="vinSearchMessage" class="mt-2 d-none"></div>
                </div>

                <div id="vehicleResult" class="d-none">
                    <hr />
                    <h6 class="fw-semibold mb-3">Vehicle Found</h6>
                    <input type="hidden" id="foundVehicleId" />
                    <div class="row g-2">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">VIN</label>
                            <input class="form-control" id="resultVin" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Brand</label>
                            <input class="form-control" id="resultBrand" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Model</label>
                            <input class="form-control" id="resultModel" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Year</label>
                            <input class="form-control" id="resultYear" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Color</label>
                            <input class="form-control" id="resultColor" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Type</label>
                            <input class="form-control" id="resultType" disabled />
                        </div>
                    </div>
                </div>

                <div id="addVehicleError" class="alert alert-danger mt-3 d-none"></div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" id="btnCancelModal"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="button" class="btn btn-primary d-none" id="btnAddVehicle">
                    <i class="fas fa-plus"></i> Add to Service
                </button>
            </div>

        </div>
    </div>
</div>

<div class="modal fade" id="removeVehicleModal" tabindex="-1"
     aria-labelledby="removeVehicleModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="removeVehicleModalLabel">
                    <i class="fas fa-times-circle"></i> Remove Vehicle from Service
                </h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                Are you sure you want to remove vehicle
                <strong id="removeVehicleVin"></strong>
                from this service?
                <br />
                <span class="text-muted small">
                    This will also delete all service records associated with this vehicle in this service.
                </span>
                <div id="removeVehicleError" class="alert alert-danger mt-3 d-none"></div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="button" class="btn btn-danger" id="btnConfirmRemove">
                    <i class="fas fa-times"></i> Remove
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/vehicleServiceDetails.js" asp-append-version="true"></script>
}