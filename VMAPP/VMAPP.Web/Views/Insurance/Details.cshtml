@model InsuranceCompanyDetailsViewModel
@using VMAPP.Web.Models.InsuranceModels
@{
    ViewData["Title"] = "Insurance Company Details — " + Model.Name;
}

<div class="table-wrapper">
    <div class="table-box">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>@ViewData["Title"]</h2>
            @if (User.IsInRole(VMAPP.Common.GlobalConstant.AdministratorRoleName))
            {
                <a asp-controller="Insurance" asp-action="Index" class="btn btn-secondary btn-sm">
                    <i class="fas fa-arrow-left"></i> Back to List
                </a>
            }
        </div>

        <div class="card mb-4">
            <div class="card-header fw-semibold text-dark">
                Company Information
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Name</label>
                        <input class="form-control" value="@Model.Name" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">City</label>
                        <input class="form-control" value="@Model.City" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Address</label>
                        <input class="form-control" value="@Model.Address" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Created On</label>
                        <input class="form-control" value="@Model.CreatedOn.ToString("dd.MM.yyyy")" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Email</label>
                        <input class="form-control" value="@Model.Email" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Phone</label>
                        <input class="form-control" value="@Model.Phone" disabled />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea class="form-control" rows="3" disabled>@Model.Description</textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Insured Vehicles (@Model.Vehicles.Count)</h5>
            <button type="button" class="btn btn-primary btn-sm"
                    data-bs-toggle="modal" data-bs-target="#addPolicyModal">
                <i class="fas fa-plus"></i> Add Policy
            </button>
        </div>

        <table id="vehiclesTable"
               class="datatable table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>VIN</th>
                    <th>Brand</th>
                    <th>Model</th>
                    <th>Year</th>
                    <th>Color</th>
                    <th>Type</th>
                    <th>Policy Number</th>
                    <th class="text-center action-col">Details</th>
                    <th class="text-center action-col">Delete</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var vehicle in Model.Vehicles)
                {
                    <tr>
                        <td class="fw-semibold">@vehicle.VIN</td>
                        <td>@vehicle.CarBrand</td>
                        <td>@vehicle.CarModel</td>
                        <td>@vehicle.CreatedOnYear</td>
                        <td>@vehicle.Color</td>
                        <td>@vehicle.VehicleType</td>
                        <td>@(vehicle.PolicyNumber ?? "—")</td>
                        <td class="text-center action-col">
                            <a asp-controller="Insurance"
                               asp-action="PolicyDetails"
                               asp-route-id="@vehicle.PolicyId"
                               class="btn btn-info btn-sm">
                                <i class="fas fa-info-circle"></i> Details
                            </a>
                        </td>
                        <td class="text-center action-col">
                            <button type="button"
                                    class="btn btn-danger btn-sm btn-delete-policy"
                                    data-policy-id="@vehicle.PolicyId"
                                    data-policy-number="@(vehicle.PolicyNumber ?? $"Policy #{vehicle.PolicyId}")">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>

@Html.AntiForgeryToken()
<input type="hidden" id="currentCompanyId" value="@Model.Id" />

<div class="modal fade" id="addPolicyModal" tabindex="-1"
     aria-labelledby="addPolicyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addPolicyModalLabel">
                    <i class="fas fa-plus"></i> Add Policy
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Search by VIN</label>
                    <div class="input-group">
                        <input type="text" id="vinSearchInput"
                               class="form-control text-uppercase"
                               placeholder="Enter 17-character VIN..."
                               maxlength="17" />
                        <button class="btn btn-outline-primary" type="button" id="btnSearchVin">
                            <i class="fas fa-search"></i> Search
                        </button>
                    </div>
                    <div id="vinSearchMessage" class="mt-2 d-none"></div>
                </div>

                <div id="vehicleResult" class="d-none">
                    <hr />
                    <h6 class="fw-semibold mb-3">Vehicle Found</h6>
                    <input type="hidden" id="foundVehicleId" />
                    <div class="row g-2 mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">VIN</label>
                            <input class="form-control" id="resultVin" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Brand</label>
                            <input class="form-control" id="resultBrand" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Model</label>
                            <input class="form-control" id="resultModel" disabled />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Year</label>
                            <input class="form-control" id="resultYear" disabled />
                        </div>
                    </div>
                    <hr />
                    <h6 class="fw-semibold mb-3">Policy Details</h6>
                    <div class="row g-2">
                        <div class="col-md-12">
                            <label class="form-label fw-semibold">Policy Number</label>
                            <input type="text" id="addPolicyNumber" class="form-control"
                                   placeholder="e.g. POL-2024-00001" maxlength="50" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                Start Date <span class="text-danger">*</span>
                            </label>
                            <input type="date" id="addStartDate" class="form-control" />
                            <div id="addStartDateError" class="text-danger small d-none"></div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                End Date <span class="text-danger">*</span>
                            </label>
                            <input type="date" id="addEndDate" class="form-control" />
                            <div id="addEndDateError" class="text-danger small d-none"></div>
                        </div>
                    </div>
                </div>

                <div id="addPolicyError" class="alert alert-danger mt-3 d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary d-none" id="btnSubmitAddPolicy">
                    <i class="fas fa-save"></i> Save Policy
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deletePolicyModal" tabindex="-1"
     aria-labelledby="deletePolicyModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deletePolicyModalLabel">
                    <i class="fas fa-trash"></i> Confirm Delete
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete policy
                <strong id="deletePolicyNumber"></strong>?
                <br />
                <span class="text-muted small">This will also delete all insurance claims associated with this policy.</span>
                <div id="deletePolicyError" class="alert alert-danger mt-3 d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="btnConfirmDeletePolicy">
                    <i class="fas fa-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/insuranceDetails.js" asp-append-version="true"></script>
}
