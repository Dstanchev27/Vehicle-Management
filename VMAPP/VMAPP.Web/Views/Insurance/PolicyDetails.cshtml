@model VMAPP.Web.Models.InsuranceModels.InsurancePolicyDetailsViewModel

@{
    ViewData["Title"] = "Policy Details — " + (Model.PolicyNumber ?? $"#{Model.Id}");
}

<div class="table-wrapper">
    <div class="table-box">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>@ViewData["Title"]</h2>
            <a asp-controller="Insurance"
               asp-action="Details"
               asp-route-id="@Model.InsuranceCompanyId"
               class="btn btn-secondary btn-sm">
                <i class="fas fa-arrow-left"></i> Back to Company
            </a>
        </div>

        <div class="card mb-4">
            <div class="card-header table-dark text-dark fw-semibold">
                Policy Information
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Policy Number</label>
                        <input class="form-control" value="@(Model.PolicyNumber ?? "—")" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Insurance Company</label>
                        <input class="form-control" value="@Model.InsuranceCompanyName" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Start Date</label>
                        <input class="form-control" value="@Model.StartDate.ToString("dd.MM.yyyy")" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">End Date</label>
                        <input class="form-control" value="@Model.EndDate.ToString("dd.MM.yyyy")" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Vehicle VIN</label>
                        <input class="form-control" value="@Model.VehicleVIN" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Vehicle</label>
                        <input class="form-control" value="@Model.VehicleBrand @Model.VehicleModel" disabled />
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Insurance Claims (@Model.Claims.Count)</h5>
            <button type="button" class="btn btn-primary btn-sm"
                    data-bs-toggle="modal" data-bs-target="#addClaimModal">
                <i class="fas fa-plus"></i> Add Claim
            </button>
        </div>

        <table id="claimsTable"
               class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Claim Date</th>
                    <th>Description</th>
                    <th class="text-end">Amount</th>
                    <th class="text-center action-col">Details</th>
                    <th class="text-center action-col">Delete</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var claim in Model.Claims)
                {
                    <tr>
                        <td>@claim.ClaimDate.ToString("dd.MM.yyyy")</td>
                        <td class="text-truncate" style="max-width: 300px">@claim.Description</td>
                        <td class="text-end">@claim.Amount.ToString("N2")</td>
                        <td class="text-center action-col">
                            <button type="button"
                                    class="btn btn-info btn-sm btn-claim-details"
                                    data-id="@claim.Id">
                                <i class="fas fa-info-circle"></i> Details
                            </button>
                        </td>
                        <td class="text-center action-col">
                            <button type="button"
                                    class="btn btn-danger btn-sm btn-claim-delete"
                                    data-id="@claim.Id"
                                    data-description="@claim.Description">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
</div>

@Html.AntiForgeryToken()
<input type="hidden" id="currentPolicyId" value="@Model.Id" />

<div class="modal fade" id="addClaimModal" tabindex="-1"
     aria-labelledby="addClaimModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addClaimModalLabel">
                    <i class="fas fa-plus"></i> Add Insurance Claim
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Claim Date <span class="text-danger">*</span>
                    </label>
                    <input type="date" id="addClaimDate" class="form-control" />
                    <div id="addClaimDateError" class="text-danger small d-none"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Description <span class="text-danger">*</span>
                    </label>
                    <textarea id="addClaimDescription" class="form-control" rows="3"
                              placeholder="Describe the claim..." maxlength="1500"></textarea>
                    <div id="addClaimDescriptionError" class="text-danger small d-none"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">
                        Amount <span class="text-danger">*</span>
                    </label>
                    <input type="number" id="addClaimAmount" class="form-control"
                           min="0" step="0.01" placeholder="0.00" />
                    <div id="addClaimAmountError" class="text-danger small d-none"></div>
                </div>
                <div id="addClaimError" class="alert alert-danger d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnSubmitAddClaim">
                    <i class="fas fa-save"></i> Save
                </button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="detailsClaimModal" tabindex="-1"
     aria-labelledby="detailsClaimModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detailsClaimModalLabel">
                    <i class="fas fa-info-circle"></i> Claim Details
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Claim Date</label>
                    <input type="text" id="detailsClaimDate" class="form-control" disabled />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea id="detailsClaimDescription" class="form-control" rows="4" disabled></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Amount</label>
                    <input type="text" id="detailsClaimAmount" class="form-control" disabled />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteClaimModal" tabindex="-1"
     aria-labelledby="deleteClaimModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteClaimModalLabel">
                    <i class="fas fa-trash"></i> Confirm Delete
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to delete this claim?
                <strong id="deleteClaimDescription" class="d-block mt-2 text-break"></strong>
                <div id="deleteClaimError" class="alert alert-danger mt-3 d-none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="btnConfirmDeleteClaim">
                    <i class="fas fa-trash"></i> Delete
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/insurancePolicyDetails.js" asp-append-version="true"></script>
}
